rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasChatParticipantAccess(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    function isValidUserDocFor(uid, data) {
      return data.uid == uid
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() > 0
        && data.name is string
        && data.name.size() > 0
        && data.createdAt != null;
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && isValidUserDocFor(uid, request.resource.data);

      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if hasChatParticipantAccess(resource.data.participants);

      allow create: if isSignedIn()
        && request.resource.data.id == chatId
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      allow update: if hasChatParticipantAccess(resource.data.participants)
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.id == resource.data.id;

      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(resource.data.chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants;

      allow create: if isSignedIn()
        && request.resource.data.chatId is string
        && exists(/databases/$(database)/documents/chats/$(request.resource.data.chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants
        && request.resource.data.senderId == request.auth.uid;

      allow update: if isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(resource.data.chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants;

      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    match /status/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.content is string;
      allow update: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || (
            request.resource.data.userId == resource.data.userId
            && request.resource.data.content == resource.data.content
            && request.resource.data.type == resource.data.type
          )
        );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /statusComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.statusId is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0;
      allow update, delete: if false;
    }
  }
}
